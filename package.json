{
  "name": "callboard",
  "version": "1.0.0",
  "description": "Callboard - read-only LAN viewer for a live show's timeline, backed by QLab or vMix.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "CALLBOARD_CONFIG=./config.json nodemon src/server.js",
    "mock": "USE_MOCK=1 CALLBOARD_CONFIG=./config.json node src/server.js",
    "osc-debug": "node scripts/osc-debug.js",
    "vmix-debug": "node scripts/vmix-debug.js",
    "test": "node --test test/*.test.js",
    "build:mac": "pkg . --targets node22-macos-arm64,node22-macos-x64 --out-path dist",
    "build:win": "pkg . --targets node22-win-x64 --out-path dist",
    "build": "npm run build:mac && npm run build:win",
    "package:mac": "bash build/macos/presign-tray.sh && npm run build:mac && bash build/macos/build-dmg.sh",
    "package:win": "npm run build:win && makensis build/windows/install.nsi"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.5.0",
    "osc": "^2.4.5",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "systray": "^1.0.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0",
    "nodemon": "^3.1.4"
  },
  "bin": "src/server.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "config.default.json",
      "build/icons/**/*",
      "node_modules/@fortawesome/fontawesome-free/css/**/*",
      "node_modules/@fortawesome/fontawesome-free/webfonts/**/*",
      "node_modules/systray/traybin/**/*"
    ],
    "outputPath": "dist"
  }
}
